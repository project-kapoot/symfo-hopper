{% extends 'base.html.twig' %}

{% block title %}Hall of Fame{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1>Tableau des scores</h1>
        <p class="lead">Les meilleurs joueurs de tous les temps</p>

        <div class="row justify-content-center">
            {% for player in players %}
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <img src="{{ asset('images/avatar.png') }}" alt="Avatar" class="img-fluid rounded-circle mr-3" style="width: 64px;">
                                <div>
                                    <h5 class="card-title">{{ player.name }}</h5>
                                    <h6 class="card-subtitle mb-2 text-muted">{{ player.score }} points</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
