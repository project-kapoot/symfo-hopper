<div class="answer-card card mb-3 p-3" style="background-color: #1e293b; border: 1px solid #334155; border-radius: 0.375rem;">
  <div class="answer-header d-flex justify-content-between align-items-center">
    <div class="mb-2">
      {{ form_label(answerForm.content, 'Réponse ' ~ (i + 1), {'attr': {'class': 'form-label text-white'}}) }}
    </div>   
  </div>
  
  <div class="mb-3">
    {{ form_widget(answerForm.content, {
      'attr': {
        'class': 'form-control',
        'placeholder': placeholders[i]
      }
    }) }}
  </div>
</div>